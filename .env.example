# # ===================================
# # DISASTER RAG CONFIGURATION
# # ===================================

# LLM Configuration (Local Ollama/Qwen)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:3b
# OLLAMA_TOOL_MODEL=qwen2.5:3b
# QWEN_SYSTEM_PROMPT=You are DisasterRAG's local Qwen assistant for disaster intelligence.

# # Weather API (OpenWeatherMap)
# OPENWEATHER_API_KEY=#####

# # Disaster API (EONET - NASA)
# # No API key required for EONET

# # NASA Earth Observatory
# #NASA_API_KEY=DEMO_KEY

# # Database Configuration
# SQLITE_DB_PATH=./data/disaster_rag.db
# VECTOR_DB_PATH=./data/chromadb

# # Embedding Model
# EMBEDDING_MODEL=all-MiniLM-L6-v2

# # ADS-B Data Configuration
# ADSB_DATA_PATH=./data/adsb_sample.xlsx

# # System Configuration
# MAX_TOKENS=8000
# TEMPERATURE=0.7
# TOP_P=0.9

# # Agent Configuration
# ENABLE_FLIGHT_AGENT=true
# ENABLE_WEATHER_AGENT=true
# ENABLE_DISASTER_AGENT=true
# ENABLE_CONSENSUS_AGENT=true

# # Logging
# LOG_LEVEL=INFO
# LOG_FILE=./disaster_rag.log
