# ============================================
# DISASTER MANAGEMENT RAG SYSTEM - CONFIGURATION
# Multi-File Excel Support (Sep 2025 - Jan 2026)
# ============================================

# ============================================
# LLM CONFIGURATION
# ============================================
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama3-70b-8192

# ============================================
# API KEYS
# ============================================
OPENWEATHER_API_KEY=your_openweather_api_key_here
NASA_API_KEY=DEMO_KEY

# ============================================
# DATABASE CONFIGURATION
# ============================================
SQLITE_DB_PATH=data/disaster_rag.db
VECTOR_DB_PATH=data/chromadb

# ============================================
# ADS-B DATA CONFIGURATION (UPDATED)
# ============================================
# Directory containing Excel files
ADSB_DATA_DIR=data

# Pattern to match Excel files (supports wildcards)
# Examples:
#   *.xlsx                    - All Excel files
#   *_2025.xlsx              - Files ending with _2025.xlsx
#   flight_data_*.xlsx       - Files starting with flight_data_
ADSB_FILE_PATTERN=*.xlsx

# ============================================
# DATA LOADING CONFIGURATION
# ============================================
# Number of records to load per batch (adjust based on memory)
BATCH_SIZE=10000

# Enable progress bar during loading
ENABLE_PROGRESS_BAR=true

# ============================================
# EMBEDDING MODEL
# ============================================
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ============================================
# LLM PARAMETERS
# ============================================
MAX_TOKENS=8000
TEMPERATURE=0.7
TOP_P=0.9

# ============================================
# AGENT CONFIGURATION
# ============================================
ENABLE_FLIGHT_AGENT=true
ENABLE_WEATHER_AGENT=true
ENABLE_DISASTER_AGENT=true
ENABLE_CONSENSUS_AGENT=true

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=INFO
LOG_FILE=disaster_rag.log

# ============================================
# NOTES
# ============================================
# 1. Place all Excel files in the 'data' directory
# 2. Excel files can have any name (e.g., september_2025.xlsx, oct_data.xlsx)
# 3. Each Excel file can contain multiple sheets
# 4. Run 'python data_loader.py' to load data before starting the chatbot
# 5. The system automatically extracts month/year from filenames
# 6. Files are processed in alphabetical order
